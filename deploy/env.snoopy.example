# Copy to ~/.env.snoopy on the OCI VM and fill in real values.
# This file is loaded by `podman run --env-file` — never commit it.

DISCORD_TOKEN=<YOUR_DISCORD_TOKEN>
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>

# SQLite stored in the Podman volume mounted at /data
DB_PATH=/data/snoopy_home.db

# Household settings
BOT_NAME=Snoopy
TIMEZONE=Asia/Hong_Kong
BOT_PERSONALITY=default

# Optional: restrict slash command registration to one guild for instant updates
# DISCORD_GUILD_ID=<YOUR_DISCORD_GUILD_ID>

# Optional: Google Calendar
# HOUSEHOLD_CALENDAR_ID=<YOUR_CALENDAR_ID>@group.calendar.google.com
# GOOGLE_SA_JSON_B64 — base64 of your service account JSON contents:
#   base64 -w 0 api-project-xxxxx.json   (Linux)
#   base64 -i api-project-xxxxx.json     (macOS)
# GOOGLE_SA_JSON_B64=<BASE64_ENCODED_SERVICE_ACCOUNT_JSON>

# Optional: voice TTS fallback channel
# DEFAULT_VOICE_CHANNEL_ID=<YOUR_VOICE_CHANNEL_ID>

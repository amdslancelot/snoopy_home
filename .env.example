# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Google Gemini API key (from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: set to your server ID for instant slash command registration
DISCORD_GUILD_ID=

# Bot identity
BOT_NAME=Snoopy

# Household timezone (IANA format, e.g. America/New_York, Europe/London)
TIMEZONE=UTC

# Postgres connection string (docs/prod-provisioning.md). Required — no code
# default. "dev" below is the local-only convention password for the
# loopback-bound minikube/podman Postgres used in dev; never reuse it in
# staging or prod.
DATABASE_URL=postgresql://snoopy_rw:dev@localhost:5432/snoopy_home

# Legacy SQLite file path, read only by scripts/migrate_sqlite_to_pg.py
#DB_PATH=snoopy_home.db

# Gemini model overrides (defaults shown)
# MODEL_LOW=gemini-2.0-flash
# MODEL_MEDIUM=gemini-2.5-flash
# MODEL_HIGH=gemini-2.5-pro

# Context caching TTL in seconds (Gemini minimum is 60)
CACHE_TTL_SECONDS=3600

# Number of messages per channel kept in memory for context
CONTEXT_WINDOW=20

# ── Google Calendar integration (optional) ────────────────────────────────────
# Path to a Google service account key JSON file.
# The service account must have "Make changes to events" permission on the calendar.
# GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
# HOUSEHOLD_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# ── Discord voice TTS (optional) ──────────────────────────────────────────────
# Fallback voice channel used when the target user is not currently in any voice channel.
# DEFAULT_VOICE_CHANNEL_ID=

# ── Bot personality ────────────────────────────────────────────────────────────
# "default" = warm, organised, dependable assistant
# "snoopy"  = Snoopy the beagle from Peanuts
BOT_PERSONALITY=default
